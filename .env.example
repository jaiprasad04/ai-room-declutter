# Shared PostgreSQL Connection parameters (Supabase instance)
DATABASE_URL="postgresql://postgres.your-supabase-db:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.your-supabase-db:5432/postgres"

# NextAuth Authentication Config
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"
WEBHOOK_URL="http://localhost:3000" # Set to external proxy URL (e.g. ngrok) in development

# Google OAuth API Credentials
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_google_client_secret"

# Stripe pack credit purchases configurations
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# MuAPI image processing key configurations (Get from muapi.ai)
MUAPIAPP_API_KEY="your_muapi_api_key_here"
